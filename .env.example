# Copy this file to .env and fill in your own keys. NEVER commit real keys.

# Google Gemini API key for the GPT Explanation Layer.
# Get one at https://aistudio.google.com/app/apikey
# If you regenerate a key that was ever pasted into a chat/public place, do it now.
GEMINI_API_KEY= AIzaSyAYQoc06wn3IoVa8I0rn12ak6OD1rDmGTY

# App settings
APP_ENV=development
LOG_LEVEL=INFO

# Price data source: this backend runs on a fixed Kaggle NSE historical CSV
# (app/data/source_data/nse_universe_2016_2017.csv), not live data.
# FORCE_SYNTHETIC_DATA below is currently unused dead config, kept only for
# forward compatibility -- fundamentals are unconditionally synthetic (the
# CSV has no fundamental data) and prices are unconditionally from the CSV.
FORCE_SYNTHETIC_DATA=false
